{
  "manifest_version": 3,
  "name": "AliExpress Orders Report",
  "version": "1.0",
  "description": "Export your AliExpress order history (date, order number, status, products, price, quantity) to Excel or CSV.",
  "permissions": ["activeTab", "scripting", "downloads"],
  "host_permissions": ["https://www.aliexpress.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
